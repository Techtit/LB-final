nSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"Submission"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"submittedAt"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"NextAttempt"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_NextAttempt"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"allowedDuration"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"submissionsAllowed"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"SubmissionRateLimiterConfig"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_RateLimiterConfig"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"attemptsRemainingIncreasesAt"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"maxPerInterval"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"timeIntervalDuration"},arguments:[],directives:[]}]}},{kind:"FragmentDefinition",name:{kind:"Name",value:"Attempts"},typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_Attempts"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"lastSubmission"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"LastSubmission"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"nextAttempt"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"NextAttempt"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"attemptsAllowed"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"attemptsMade"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"attemptsRemaining"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"inProgressAtte