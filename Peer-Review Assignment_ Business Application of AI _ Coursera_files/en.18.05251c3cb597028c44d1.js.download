s:[]},{kind:"Field",name:{kind:"Name",value:"assignment"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"Assignment"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"integritySettings"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"AcademicIntegritySettings"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"submitter"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"IndividualSubmitter"},directives:[]},{kind:"FragmentSpread",name:{kind:"Name",value:"TeamSubmitter"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"attempts"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"Attempts"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"feedback"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",alias:{kind:"Name",value:"feedbackId"},name:{kind:"Name",value:"id"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"outcome"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"OverallOutcome"},directives:[]}]}}]}},{kind:"Field",name:{kind:"Name",value:"outcome"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"AssignmentOutcome"},directives:[]}]}},{kind:"Field",name:{kind:"Name",value:"skillsVerifiedAt"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"gradingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"manualGradingStatus"},arguments:[],directives:[]},{kind:"Field",name:{kind:"Name",value:"warnings"},arguments:[],directives:[]}]}},{kind:"OperationDefinition",operation:"query",name:{kind:"Name",value:"QueryState"},variableDefinitions:[{kind:"VariableDefinition",variable:{kind:"Variable",name:{kind:"Name",value:"courseId"}},type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"ID"}}},directives:[]},{kind:"VariableDefinition",variable:{kind:"Variable",name:{kind:"Name",value:"itemId"}},type:{kind:"NonNullType",type:{kind:"NamedType",name:{kind:"Name",value:"ID"}}},directives:[]}],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"SubmissionState"},arguments:[],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"Field",name:{kind:"Name",value:"queryState"},arguments:[{kind:"Argument",name:{kind:"Name",value:"courseId"},value:{kind:"Variable",name:{kind:"Name",value:"courseId"}}},{kind:"Argument",name:{kind:"Name",value:"itemId"},value:{kind:"Variable",name:{kind:"Name",value:"itemId"}}}],directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"InlineFragment",typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_QueryStateFailure"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"QueryStateFailure"},directives:[]}]}},{kind:"InlineFragment",typeCondition:{kind:"NamedType",name:{kind:"Name",value:"Submission_SubmissionState"}},directives:[],selectionSet:{kind:"SelectionSet",selections:[{kind:"FragmentSpread",name:{kind:"Name",value:"QueryStateSuccess"},directives:[]}]}}]}}]}}]}}],loc:{start:0,end:10925}};n.loc.source={body:'#import "./AssignmentFragments.graphql"\n#import "./PartFragments.graphql"\n\n# To avoid issues with Apollo caching, we alias many `id` fields to use a different field name other than id when the\n# __typename + ID combination is not unique across all instances of the type.\n# An option ID can be exactly the same across different questions (e.g. if a question was duplicated), and the 2\n# unrelated options with the same ID must not be considered the same object in the Apollo cache.\n# If no `id` or `_id` field exists on an object (e.g. due to aliasing id to a different name), Apollo will cache the\n# object as part of the parent object instead of its own unique cache entry, which is what we want in many cases.\n\nfragment CheckboxQuestion on Submission_CheckboxQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  checkboxResponse: response {\n    chosen\n  }\n}\n\nfragment CheckboxReflectQuestion on Submission_CheckboxReflectQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  checkboxReflectResponse: response {\n    chosen\n  }\n}\n\nfragment CodeExpressionQuestion on Submission_CodeExpressionQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    codeLanguage\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n    replEvaluatorId\n    starterCode {\n      code\n    }\n  }\n  codeExpressionResponse: response {\n    answer {\n      code\n    }\n  }\n}\n\nfragment FileUploadQuestion on Submission_FileUploadQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    allowedFiles\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  fileUploadResponse: response {\n    caption\n    fileUrl\n    title\n  }\n}\n\nfragment MathQuestion on Submission_MathQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  mathResponse: response {\n    answer\n  }\n}\n\nfragment MultipleChoiceQuestion on Submission_MultipleChoiceQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  multipleChoiceResponse: response {\n    chosen\n  }\n}\n\nfragment MultipleChoiceReflectQuestion on Submission_MultipleChoiceReflectQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    options {\n      ...Option\n    }\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  multipleChoiceReflectResponse: response {\n    chosen\n  }\n}\n\nfragment MultipleChoiceFillableBlank on Submission_MultipleChoiceFillableBlank {\n  fillableBlankId: id\n  answerOptions {\n    ...Option\n  }\n}\n\nfragment MultipleChoiceFillableBlankResponse on Submission_MultipleChoiceFillableBlankResponse {\n  responseId: id\n  optionId\n}\n\nfragment MultipleFillableBlanksResponse on Submission_MultipleFillableBlanksQuestionResponse {\n  responses {\n    ...MultipleChoiceFillableBlankResponse\n  }\n}\n\nfragment MultipleFillableBlanksQuestion on Submission_MultipleFillableBlanksQuestion {\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n    fillableBlanks {\n      ...MultipleChoiceFillableBlank\n    }\n  }\n  multipleFillableBlanksResponse: response {\n    ...MultipleFillableBlanksResponse\n  }\n  gradeSettings {\n    maxScore\n  }\n}\n\nfragment NumericQuestion on Submission_NumericQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  numericResponse: response {\n    answer\n  }\n}\n\nfragment OffPlatformQuestion on Submission_OffPlatformQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n}\n\nfragment PlainTextQuestion on Submission_PlainTextQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  plainTextResponse: response {\n    plainText\n  }\n}\n\nfragment RegexQuestion on Submission_RegexQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  regexResponse: response {\n    answer\n  }\n}\n\nfragment RichTextQuestion on Submission_RichTextQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  richTextResponse: response {\n    richText {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n}\n\nfragment TextExactMatchQuestion on Submission_TextExactMatchQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  textExactMatchResponse: response {\n    answer\n  }\n}\n\nfragment TextReflectQuestion on Submission_TextReflectQuestion {\n  gradeSettings {\n    maxScore\n  }\n  partId: id\n  questionSchema {\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  textReflectResponse: response {\n    answer\n  }\n}\n\nfragment UrlQuestion on Submission_UrlQuestion {\n  gradeSettings {\n    maxScore\n    graderType\n  }\n  partId: id\n  questionSchema {\n    plagiarismCheckStatus\n    prompt {\n      ...SubmissionCmlContent\n      ...SubmissionHtmlContent\n    }\n  }\n  urlResponse: response {\n    caption\n    title\n    url\n  }\n}\n\nfragment WidgetQuestion on Submission_WidgetQue